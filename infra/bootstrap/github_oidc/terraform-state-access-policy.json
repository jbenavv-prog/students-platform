{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListTerraformStateBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetBucketVersioning"
      ],
      "Resource": "arn:aws:s3:::YOUR_TF_STATE_BUCKET"
    },
    {
      "Sid": "ManageTerraformStateObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::YOUR_TF_STATE_BUCKET/*"
    }
  ]
}
